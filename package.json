{
  "name": "claude-session-manager",
  "productName": "Claude Session Manager",
  "version": "1.0.1",
  "description": "Gestionnaire graphique de sessions Claude Code pour macOS",
  "main": "dist/main/main.js",
  "scripts": {
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "webpack --config webpack.renderer.config.js --mode production",
    "copy:html": "cp src/renderer/index.html dist/renderer/index.html",
    "build": "npm run build:main && npm run build:renderer && npm run copy:html",
    "dev:main": "tsc -p tsconfig.main.json && electron .",
    "dev:renderer": "webpack --config webpack.renderer.config.js --mode development --watch",
    "start": "npm run build && electron .",
    "dev": "concurrently \"npm run dev:renderer\" \"sleep 3 && npm run dev:main\"",
    "dist": "npm run build && electron-builder --mac",
    "dist:dmg": "npm run build && electron-builder --mac dmg",
    "dist:zip": "npm run build && electron-builder --mac zip"
  },
  "author": "Leo Marcel",
  "license": "MIT",
  "build": {
    "appId": "com.leomarcel.claude-session-manager",
    "productName": "Claude Session Manager",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "!node_modules/.cache"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "Claude Session Manager",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "concurrently": "^8.2.2",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^6.9.1",
    "electron": "^28.2.0",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "style-loader": "^3.3.4",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "node-pty": "^1.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-web-links": "^0.9.0"
  }
}
