# App-specific password for notarization
# Generate at: https://appleid.apple.com > Sign-In and Security > App-Specific Passwords
# Format: xxxx-xxxx-xxxx-xxxx
APPLE_APP_SPECIFIC_PASSWORD=

# GitHub personal access token for publishing releases (optional, only needed with --publish)
# Generate at: https://github.com/settings/tokens (scope: repo)
# Or leave empty if 'gh' CLI is authenticated (the script will read it automatically)
GH_TOKEN=
